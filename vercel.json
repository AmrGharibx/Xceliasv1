{
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://www.gstatic.com https://*.firebasedatabase.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.googleapis.com https://*.firebasedatabase.app wss://*.firebasedatabase.app; img-src 'self' data:; frame-src 'self' https://lms.xcelias.com https://*.firebasedatabase.app; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'" }
      ]
    },
    {
      "source": "/activities/(.*).jsx",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/website/(.*)",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/website/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/activities", "destination": "/activities/index.html" },
    { "source": "/content", "destination": "/content/index.html" },
    { "source": "/reports", "destination": "/reports/index.html" },
    { "source": "/studyguide", "destination": "/studyguide/index.html" },
    { "source": "/website", "destination": "/website/index.html" }
  ]
}
